generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id
  email       String?     @unique
  displayName String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspaces  Workspace[]
  sessions    Session[]
}

model Workspace {
  id          String      @id
  userId      String?
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User?       @relation(fields: [userId], references: [id])
  sessions    Session[]
  artifacts   Artifact[]
  memoryItems MemoryItem[]
  metrics     MetricSnapshot[]
  events      TimelineEvent[]
  tasks       AgentTask[]
  toolCalls   ToolCall[]
  causalPaths CausalPath[]
  panelStates PanelState[]
}

model Session {
  id          String      @id
  workspaceId String?
  userId      String?
  title       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])
  messages    Message[]
}

model Message {
  id        String   @id
  sessionId String
  role      String
  content   String
  status    String?
  metadata  Json?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
  @@index([sessionId, createdAt])
}

model TimelineEvent {
  id              String    @id
  workspaceId     String
  title           String
  description     String?
  type            String
  severity        String
  relatedPanelIds Json
  timestamp       DateTime  @default(now())
  metadata        Json?
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  @@index([workspaceId, timestamp])
}

model Artifact {
  id              String    @id
  workspaceId     String
  kind            String
  title           String
  content         String
  metadata        Json?
  relatedPanelIds Json
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  @@index([workspaceId, updatedAt])
}

model MemoryItem {
  id              String    @id
  workspaceId     String
  scope           String
  title           String
  content         String
  tags            Json?
  relatedPanelIds Json
  embeddingId     String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  @@index([workspaceId, scope])
  @@index([workspaceId, updatedAt])
}

model MetricSnapshot {
  id          String    @id
  workspaceId String
  timestamp   DateTime  @default(now())
  metrics     Json
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  @@index([workspaceId, timestamp])
}

model AgentTask {
  id              String    @id
  workspaceId     String
  title           String
  description     String?
  status          String
  assignedAgentId String
  progress        Float
  relatedPanelIds Json
  metadata        Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  @@index([workspaceId, status])
}

model ToolCall {
  id          String    @id
  workspaceId String
  sessionId   String?
  toolName    String
  args        Json?
  result      Json?
  ok          Boolean
  error       String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  @@index([workspaceId, createdAt])
  @@index([toolName])
}

model CausalPath {
  id          String    @id
  workspaceId String
  title       String
  confidence  Float
  nodes       Json
  edges       Json
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  @@index([workspaceId, createdAt])
}

model PanelState {
  id          String    @id
  workspaceId String
  panelId     String
  config      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  @@unique([workspaceId, panelId])
}
