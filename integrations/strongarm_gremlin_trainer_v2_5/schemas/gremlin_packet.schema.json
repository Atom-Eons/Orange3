{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gremlin Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "role",
    "voice",
    "decision",
    "trigger_level",
    "uncensored_view",
    "best_moves",
    "objections",
    "missing_info",
    "handoff",
    "confidence"
  ],
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "gremlin"
      ]
    },
    "voice": {
      "type": "string",
      "enum": [
        "Unfiltered"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "support",
        "revise",
        "escalate",
        "block"
      ]
    },
    "trigger_level": {
      "type": "string",
      "enum": [
        "calm",
        "alert",
        "attack"
      ]
    },
    "uncensored_view": {
      "type": "string",
      "minLength": 1,
      "maxLength": 900
    },
    "best_moves": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "objections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "missing_info": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 3
    },
    "handoff": {
      "type": "string",
      "minLength": 1,
      "maxLength": 700
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    }
  }
}
